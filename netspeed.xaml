<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        Width="240" Height="36">
    <Border x:Name="MainBorder" CornerRadius="8" Padding="4,4,4,4"
            BorderBrush="#33FFFFFF" BorderThickness="0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#80000000" Opacity="0.4"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border x:Name="SettingsBtn" Width="18" Height="18" CornerRadius="3" Background="#30FFFFFF" Cursor="Hand" ToolTip="Open settings">
                <TextBlock x:Name="SettingsIcon" Text="&#x26A1;" FontSize="13" Foreground="#DDFFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="  "/>
            <TextBlock x:Name="DownloadIcon" Text="&#x25BC;" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text=" "/>
            <TextBlock x:Name="DownloadSpeed" Text="0.00 MB/s" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
            <TextBlock Text="  "/>
            <TextBlock x:Name="UploadIcon" Text="&#x25B2;" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text=" "/>
            <TextBlock x:Name="UploadSpeed" Text="0.00 MB/s" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
